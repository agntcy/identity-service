# Cross-domain agent remediation stack — environment template
# Copy to .env and fill in the change-me-* values.
#   cp .env.example .env

# ── Keycloak A (Org A) ─────────────────────────────────────────────────────
KC_A_ADMIN=admin
KC_A_ADMIN_PASSWORD=change-me-kc-a-admin
KC_A_HTTP_PORT=8082

# ── Keycloak B (Org B) ─────────────────────────────────────────────────────
KC_B_ADMIN=admin
KC_B_ADMIN_PASSWORD=change-me-kc-b-admin
KC_B_HTTP_PORT=8083

# ── Agent credentials (must match realm JSON secrets) ──────────────────────
OPENCODE_CLIENT_SECRET=demo-opencode-secret-change-me
TRIAGE_CLIENT_SECRET=demo-triage-secret-change-me
SUB_AGENT_CLIENT_SECRET=demo-subagent-secret-change-me

# ── Sarah's Keycloak A credentials ─────────────────────────────────────────
# NOTE: SARAH_PASSWORD, OPENCODE_CLIENT_SECRET, TRIAGE_CLIENT_SECRET, and
# SUB_AGENT_CLIENT_SECRET are baked into the realm-import JSON files under
# keycloak-a/ and keycloak-b/ — they must match those files exactly, not be
# freely changed like the other change-me-* values below.
SARAH_USER=sarah
SARAH_PASSWORD=demo-sarah-password-change-me
SARAH_EMAIL=sarah@org-a.example

# ── ID-JAG issuer ──────────────────────────────────────────────────────────
IDJAG_PORT=9002
ASSERTION_TTL=300

# ── AGNTCY Identity Node ───────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=change-me-postgres
DB_NAME=identity
VAULT_DEV_ROOT_TOKEN=change-me-devroot
IDENTITY_NODE_REST_PORT=4005
IDENTITY_NODE_GRPC_PORT=4006
IAM_ORGANIZATION=cross-domain-demo
SECRETS_CRYPTO_KEY=change-me-crypto-key-min-16-chars

# ── Gitea ───────────────────────────────────────────────────────────────────
GITEA_HTTP_PORT=3002
GITEA_SSH_PORT=2223
GITEA_ROOT_URL=http://localhost:3002/
GITEA_ADMIN_USER=demo-admin
GITEA_ADMIN_PASSWORD=change-me-gitea-admin
GITEA_ADMIN_EMAIL=admin@example.com
GITEA_GATEWAY_PORT=9103

# ── Agent ports ─────────────────────────────────────────────────────────────
OPENCODE_PORT=8100
TRIAGE_PORT=8200
SUB_AGENT_PORT=8300

# ── Demo defaults ───────────────────────────────────────────────────────────
SCAN_REPO=demo-admin/payments-service

# ── AGNTCY Directory Node ──────────────────────────────────────────────────
DIR_POSTGRES_PASSWORD=postgres
DIR_APISERVER_PORT=8888
DIR_ZOT_PORT=5556

# ── Demo webapp ─────────────────────────────────────────────────────────────
WEBAPP_PORT=8090
