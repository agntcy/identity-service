########################
# GO CONF
########################
SERVER_HTTP_HOST=:4000
SERVER_GRPC_HOST=:4001
GO_ENV=development
LOG_LEVEL=DebugLevel
API_URL=http://localhost:4000
SECRETS_CRYPTO_KEY=

########################
# DB
########################
DB_HOST=
DB_PORT=5432
DB_NAME=identity
DB_USERNAME=
DB_PASSWORD=
DB_USE_SSL=

########################
# VAULT
########################
KEY_STORE_TYPE=vault # possible values: vault, awssm
VAULT_HOST=
VAULT_PORT=8200
VAULT_USE_SSL=

########################
# AWS (Secrets Manager)
########################
AWS_REGION=
AWS_SECRETS_PREFIX=

########################
# IDENTITY
########################
IDENTITY_HOST=
IDENTITY_PORT=
UNIQUE_ISSUER_PER_TENANT=

########################
# IAM
########################
IAM_MULTI_TENANT=false
IAM_ORGANIZATION=default
IAM_ISSUER=
IAM_USER_CID_CLAIM_NAME=
IAM_USER_CID=

########################
# JWT PROVIDER
########################
# JWT_PROVIDER can be "okta" (default) or "keycloak"
JWT_PROVIDER=okta

# Keycloak Configuration (only used when JWT_PROVIDER=keycloak)
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_REALM=

# Keycloak Multi-Tenant Configuration
KEYCLOAK_MULTI_TENANT=false
KEYCLOAK_TENANT_CLAIM_NAME=tenant_id
KEYCLOAK_USER_CLAIM_NAME=preferred_username
KEYCLOAK_ORG_CLAIM_NAME=organization

########################
# WEB APPROVAL
#########################
WEB_APPROVAL_EMAIL=
WEB_APPROVAL_PUB_KEY=
WEB_APPROVAL_PRIV_KEY=
